OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_TEXT_MODELS=openai/gpt-4o-mini
# Image model quick switch:
# - Put your preferred image model in OPENAI_IMAGE_MODEL.
# - OPENAI_IMAGE_MODELS is a comma-separated priority list (first value is used first).
OPENAI_IMAGE_MODEL=google/gemini-2.5-flash-image
OPENAI_IMAGE_MODELS=google/gemini-3.1-flash-image-preview-20260226,google/gemini-2.5-flash-image
OPENAI_IMAGE_SIZE=512x512
OPENAI_MAX_TOKENS=800
OPENAI_IMAGE_TIMEOUT_MS=90000
ENABLE_CREDIT_FALLBACK=true
OPENAI_FALLBACK_TEXT_MODEL=openai/gpt-oss-20b:free
AI_FALLBACK_IMAGE_BASE_URL=https://image.pollinations.ai/prompt
# Frontend image rendering reliability:
# backend /image-proxy allows only these hosts by default (comma-separated).
IMAGE_PROXY_ALLOWED_HOSTS=image.pollinations.ai,openrouter.ai,oaistatic.com,oaiusercontent.com
MONGODB_URI=
PORT=4000
